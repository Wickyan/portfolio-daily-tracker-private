# OS generated files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Temporary files
*.tmp
*.temp
.cache/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Engine: keep examples, ignore user data ──
engine/portfolio/config.json
engine/portfolio/holdings/*.json
!engine/portfolio/holdings/example.json
engine/portfolio/snapshots/
engine/portfolio/history.csv
engine/reports/

# ── Dashboard: build artifacts ──
dashboard/frontend/node_modules/
dashboard/frontend/dist/
dashboard/frontend/.vite/

# ── Dashboard: private config & data (NEVER commit these) ──
dashboard/config.json
dashboard/data/
!dashboard/data/portfolio.example.json
!dashboard/config.example.json

# ── Dashboard: browser-mcp ──
dashboard/tools/browser-mcp/node_modules/
dashboard/tools/browser-mcp/package-lock.json

# ── Python ──
__pycache__/
*.pyc
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Docker ──
.env
.env.*
!.env.example
docker-compose.override.yml
